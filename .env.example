APP_NAME="SDIT Labitech Insan Mulia"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://namadomain.com

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=nama_database_hostinger
DB_USERNAME=user_database_hostinger
DB_PASSWORD=password_database_hostinger

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync

CACHE_STORE=file

MAIL_MAILER=smtp
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_USERNAME=email@namadomain.com
MAIL_PASSWORD=password_email
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS="email@namadomain.com"
MAIL_FROM_NAME="${APP_NAME}"

# Admin credentials — isi sesuai kebutuhan, JANGAN commit nilai asli
ADMIN1_NAME=
ADMIN1_EMAIL=
ADMIN1_PASSWORD=

ADMIN2_NAME=
ADMIN2_EMAIL=
ADMIN2_PASSWORD=

ADMIN3_NAME=
ADMIN3_EMAIL=
ADMIN3_PASSWORD=
